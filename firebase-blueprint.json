{
  "entities": {
    "Chat": {
      "title": "Chat",
      "description": "A conversation session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["userId", "title", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within a chat session",
      "type": "object",
      "properties": {
        "role": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["role", "content", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User preferences and settings",
      "type": "object",
      "properties": {
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["theme", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user preferences and profile data"
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Stores user chat sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores individual messages within a chat session"
    }
  }
}
