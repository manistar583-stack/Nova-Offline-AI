rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Primitive Helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { 
      return request.auth != null && request.auth.token.email_verified == true; 
    }

    // 3. Validation Blueprints
    function isValidChat(data) {
      return data.keys().hasAll(['userId', 'title', 'createdAt']) && 
             data.keys().size() == 3 &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.createdAt == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['role', 'content', 'createdAt']) &&
             data.keys().size() == 3 &&
             data.role is string && data.role.size() <= 20 &&
             data.content is string && data.content.size() <= 100000 &&
             data.createdAt == request.time;
    }

    // 4. Collection Rules
    match /chats/{chatId} {
      allow create: if isSignedIn() && isValidId(chatId) && isValidChat(incoming());
      
      // Updates usually don't happen but let's say we change title
      allow update: if isSignedIn() && isValidId(chatId) && isValidChat(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title'])
      );

      // Only owner can read, and no client delegation.
      allow get: if isSignedIn() && isValidId(chatId) && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && isValidId(chatId) && existing().userId == request.auth.uid;

      match /messages/{messageId} {
        allow create: if isSignedIn() && isValidId(messageId) && isValidMessage(incoming()) && 
                      get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;

        // Existing messages can't be updated or deleted in this app based on what I see
        
        allow get: if isSignedIn() && isValidId(messageId) && 
                   get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
        // List query delegation:
        allow list: if isSignedIn() && 
                    get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
      }
    }
  }
}
