rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function incoming() {
      return request.resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidChat(data) {
      return data.keys().hasAll(['userId', 'title']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.title is string && data.title.size() <= 1000;
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidChat(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidChat(incoming()) && incoming().userId == resource.data.userId;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      function isValidMessage(data) {
        return data.keys().hasAll(['role', 'content']) &&
               data.role is string && (data.role == 'user' || data.role == 'assistant') &&
               data.content is string && data.content.size() <= 100000;
      }
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
        allow create: if isSignedIn() && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid && isValidMessage(incoming());
      }
    }
  }
}
